<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.UnitConverter" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="CustomCardView" parent="">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="CustomChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipCornerRadius">24dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipBackgroundColor">@color/chip_unselected</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="chipMinHeight">40dp</item>
        <item name="textStartPadding">16dp</item>
        <item name="textEndPadding">16dp</item>
    </style>

    <style name="ConvertButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="CustomSpinner" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <style name="CustomEditText" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxBackgroundColor">@color/input_background</item>
        <item name="hintTextColor">@color/primary</item>
    </style>
</resources>