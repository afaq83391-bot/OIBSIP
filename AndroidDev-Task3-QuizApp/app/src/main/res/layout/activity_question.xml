<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Top Bar: Score + Question Counter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-bold"
            android:text="Score: 0"
            android:textColor="@color/primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tv_question_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Question 1 of 12"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:max="12"
        android:progress="1"
        android:progressBackgroundTint="@color/progress_bg"
        android:progressTint="@color/primary" />

    <!-- Question Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <TextView
            android:id="@+id/tv_question_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingExtra="4dp"
            android:text="What is the chemical symbol for Gold?"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />
    </androidx.cardview.widget.CardView>

    <!-- Options -->
    <LinearLayout
        android:id="@+id/options_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_option_a"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_option_normal"
            android:fontFamily="sans-serif-medium"
            android:gravity="center|start"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:text="Option A"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_option_b"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_option_normal"
            android:fontFamily="sans-serif-medium"
            android:gravity="center|start"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:text="Option B"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_option_c"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_option_normal"
            android:fontFamily="sans-serif-medium"
            android:gravity="center|start"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:text="Option C"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_option_d"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_option_normal"
            android:fontFamily="sans-serif-medium"
            android:gravity="center|start"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:text="Option D"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Next Button -->
    <Button
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_button_primary"
        android:fontFamily="sans-serif-bold"
        android:text="NEXT"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:visibility="gone"
        android:elevation="6dp" />

</LinearLayout>